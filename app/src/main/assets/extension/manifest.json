{
  "manifest_version": 2,
  "name": "AppBlocker",
  "version": "1.0",
  "description": "Built-in network and cosmetic blocker",
  "browser_specific_settings": {
    "gecko": {
      "id": "appblocker@local",
      "strict_min_version": "68.0"
    }
  },
  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "<all_urls>"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start",
      "all_frames": true
    }
  ]
}